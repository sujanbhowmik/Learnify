    <script>
        // স্ক্রল অ্যানিমেশন
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                var elementVisible = 150;
                
                if (elementTop < windowHeight - elementVisible) {
                    reveals[i].classList.add("active");
                }
            }
        }
        
        window.addEventListener("scroll", reveal);
        reveal(); // Initialize
        
        // নেভিগেশন লিংক ক্লিক করার সময় smooth স্ক্রল
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                
                const targetId = this.getAttribute('href');
                if(targetId === '#') return;
                
                const targetElement = document.querySelector(targetId);
                if(targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 80,
                        behavior: 'smooth'
                    });
                }
            });
        });
        
        // বাটন ক্লিক অ্যানিমেশন
        const buttons = document.querySelectorAll('.btn');
        buttons.forEach(button => {
            button.addEventListener('click', function(e) {
                if(this.getAttribute('type') === 'submit') return;
                
                e.preventDefault();
                
                // Add animation class
                this.classList.add('btn-animate');
                
                // Remove animation class after animation completes
                setTimeout(() => {
                    this.classList.remove('btn-animate');
                    
                    // Navigate to link after animation
                    const href = this.getAttribute('href');
                    if(href && href !== '#') {
                        if(href.startsWith('http')) {
                            window.open(href, '_blank');
                        } else {
                            window.location.href = href;
                        }
                    }
                }, 300);
            });
        });
        
        // অর্ডার ফর্ম হ্যান্ডলিং
        const orderForm = document.getElementById('orderForm');
        let orders = JSON.parse(localStorage.getItem('orders')) || [];
        
        orderForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = {
                name: document.getElementById('name').value,
                paymentNumber: document.getElementById('paymentNumber').value,
                email: document.getElementById('email').value,
                transactionNumber: document.getElementById('transactionNumber').value,
                date: new Date().toLocaleString()
            };
            
            orders.push(formData);
            localStorage.setItem('orders', JSON.stringify(orders));
            
            alert('ধন্যবাদ! আপনার অর্ডারটি গ্রহণ করা হয়েছে। দয়া করে আমাদের হোয়াটসঅ্যাপে যোগাযোগ করুন। ');
            orderForm.reset();
        });
        
        // এক্সেল এক্সপোর্ট ফাংশন
        function exportToExcel() {
            if(orders.length === 0) {
                alert('কোনো অর্ডার ডেটা পাওয়া যায়নি।');
                return;
            }
            
            // Worksheet তৈরি করা
            const ws = XLSX.utils.json_to_sheet(orders);
            
            // Workbook তৈরি করা
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Orders");
            
            // Excel फাইল ডাউনলোড করা
            XLSX.writeFile(wb, "learnify_orders.xlsx");
        }
    </script>
